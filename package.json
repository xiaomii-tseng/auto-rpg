{
  "name": "auto-rpg",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "server": "ng serve --host 0.0.0.0 --configuration=uat",
    "server-uat": "ng serve --host 0.0.0.0 --configuration=uat",
    "build-uat": "ng build --configuration=uat",
    "deploy": "ng build --base-href /auto-rpg/ && node deploy.mjs",
    "push": "powershell -ExecutionPolicy Bypass -File push-update.ps1"
  },
  "private": true,
  "packageManager": "npm@11.3.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.0",
    "colyseus.js": "^0.16.22",
    "phaser": "^3.90.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.0",
    "angular-cli-ghpages": "^3.0.3",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}

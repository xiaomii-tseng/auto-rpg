{
  "compilerOptions": {
    "target":         "ES2020",
    "module":         "commonjs",
    "lib":            ["ES2020"],
    "outDir":         "./dist",
    "rootDir":        "..",
    "strict":                  true,
    "experimentalDecorators":  true,
    "emitDecoratorMetadata":   true,
    "esModuleInterop":         true,
    "resolveJsonModule": true,
    "paths": {
      "@shared/*": ["../shared/*"]
    }
  },
  "include": ["src/**/*", "../shared/**/*"]
}
